# ============================================================
# 物业管理系统 - 环境变量配置模板
# 使用方法：复制此文件为 .env，修改对应的值
# cp .env.example .env
# ============================================================

# -----------------------------------------------------------
# MySQL 数据库配置
# -----------------------------------------------------------
MYSQL_ROOT_PASSWORD=Property@2024
MYSQL_DATABASE=property_managementone
MYSQL_USER=property
MYSQL_PASSWORD=Property@2024
MYSQL_PORT=3306

# -----------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------
REDIS_PASSWORD=PropertyRedis@2024
REDIS_PORT=6379

# -----------------------------------------------------------
# 后端服务配置
# -----------------------------------------------------------
BACKEND_PORT=8080

# JWT 密钥（生产环境务必修改！）
JWT_SECRET=propertyManagementSecretKey2024Prod

# -----------------------------------------------------------
# 前端端口配置
# -----------------------------------------------------------
# 管理员端端口（对外主入口）
ADMIN_PORT=80
# 业主端 H5 端口
OWNER_PORT=8081

# -----------------------------------------------------------
# 其他配置
# -----------------------------------------------------------
# 时区
TZ=Asia/Shanghai

# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC
